# ── FortiEDR MCP Server – Instance Configuration Template ────────────────────
# Copy this file to .env.<cliente>, fill in the values and remove all comments.
# Never commit files containing real credentials to source control.
# ─────────────────────────────────────────────────────────────────────────────

# FortiEDR connection
# Hostname or IP of the FortiEDR Central Manager
FORTIEDR_HOST=

# API username (local account or LDAP)
FORTIEDR_USER=

# API password
FORTIEDR_PASSWORD=

# HTTPS port (default: 443)
FORTIEDR_PORT=443

# Set to true for production with valid certificates
# false is safe for self-signed certs in lab/test environments
FORTIEDR_VERIFY_SSL=false

# MCP server settings
# Port the MCP server listens on inside the container
MCP_SERVER_PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
