# ── FortiEDR MCP Server – Instance Configuration Template ────────────────────
# Copy this file to .env.<cliente> and fill in the values for each instance.
# Never commit files containing real credentials to source control.
# ─────────────────────────────────────────────────────────────────────────────

# FortiEDR connection settings
FORTIEDR_HOST=            # Hostname or IP of the FortiEDR Central Manager
                          # Example: fortiedr.example.com or 192.168.1.100
FORTIEDR_USER=            # API username (local account or LDAP)
FORTIEDR_PASSWORD=        # API password
FORTIEDR_PORT=443         # HTTPS port (default: 443)
FORTIEDR_VERIFY_SSL=false # Set to true for production with valid certificates
                          # false is useful for self-signed certs in lab/test

# MCP server settings
MCP_SERVER_PORT=8000      # Port the MCP server listens on inside the container
                          # Map to a host port in docker-compose.yml

# Logging
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
